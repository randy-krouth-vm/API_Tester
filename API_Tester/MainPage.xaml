<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="API_Tester.MainPage"
             Title="API Security Tester">

    <Shell.TitleView>
        <Border Padding="4,4"
                HorizontalOptions="Fill"
                Stroke="#BFD3D9"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#EAF4F3" Offset="0.0" />
                    <GradientStop Color="#E4EDF7" Offset="0.55" />
                    <GradientStop Color="#EEF1E8" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12"
                  HorizontalOptions="Fill">
                <Label Grid.Column="0"
                       Text="API Security Tester"
                       FontFamily="OpenSansSemibold"
                       FontSize="22"
                       VerticalOptions="Center"
                       TextColor="#0F172A"
                       Margin="12,0,0,0" />
                <ScrollView Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="8" Margin="0,0,10,0">
                        <Button x:Name="NavTopButton" Text="Top" Clicked="OnNavigateSectionClicked" CommandParameter="top" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavTargetButton" Text="Target" Clicked="OnNavigateSectionClicked" CommandParameter="target" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavTestsButton" Text="Tests" Clicked="OnNavigateSectionClicked" CommandParameter="tests" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavAppStandardsButton" Text="App Standards" Clicked="OnNavigateSectionClicked" CommandParameter="app-standards" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavUsFederalButton" Text="U.S. Federal" Clicked="OnNavigateSectionClicked" CommandParameter="us-federal" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavInternationalButton" Text="International" Clicked="OnNavigateSectionClicked" CommandParameter="international" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavCloudInfraButton" Text="Cloud/Infra" Clicked="OnNavigateSectionClicked" CommandParameter="cloud-infra" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavRunAllButton" Text="Run" Clicked="OnNavigateSectionClicked" CommandParameter="run" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavCveButton" Text="CVE" Clicked="OnNavigateSectionClicked" CommandParameter="cve" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavResultsButton" Text="Results" Clicked="OnNavigateSectionClicked" CommandParameter="results" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavFindButton" Text="Find" Clicked="OnFindInResultsClicked" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                        <Button x:Name="NavBottomButton" Text="Bottom" Clicked="OnNavigateSectionClicked" CommandParameter="bottom" Padding="10,6" FontSize="12" HeightRequest="32" CornerRadius="4" Margin="0,2" />
                    </HorizontalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Shell.TitleView>

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EEF7F5" Offset="0.0" />
            <GradientStop Color="#E6EEF9" Offset="0.45" />
            <GradientStop Color="#F8F5EC" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="CardBackground">#FDFEFE</Color>
            <Color x:Key="CardBorder">#D7E2E6</Color>
            <Color x:Key="PrimaryButton">#0D9488</Color>
            <Color x:Key="SecondaryButton">#6B7280</Color>
            <Color x:Key="SurfaceText">#0F172A</Color>
            <Color x:Key="MutedText">#475569</Color>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource SurfaceText}" />
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
                <Setter Property="TextColor" Value="{StaticResource SurfaceText}" />
                <Setter Property="PlaceholderColor" Value="#94A3B8" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
                <Setter Property="TextColor" Value="#94A3B8" />
                <Setter Property="TitleColor" Value="#94A3B8" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource SurfaceText}" />
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource SecondaryButton}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontFamily" Value="OpenSansSemibold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.85" />
                                    <Setter Property="Scale" Value="0.99" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView x:Name="MainScrollView" VerticalScrollBarVisibility="Always">
        <VerticalStackLayout Padding="18" Spacing="12">
            <Border x:Name="TopSectionAnchor"
                    BackgroundColor="{StaticResource CardBackground}"
                    Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1"
                    Padding="16"
                    StrokeShape="RoundRectangle 18">
                <VerticalStackLayout Spacing="6">
                    <Label Text="API Security Tester"
                           FontSize="44"
                           HorizontalOptions="Center"
                           TextColor="#0B3A5A"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Framework-driven API hardening, validation, and compliance checks"
                           HorizontalOptions="Center"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource MutedText}" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="TargetSectionAnchor" Text="Target URL" FontAttributes="Bold" />
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <ActivityIndicator x:Name="BusyIndicator"
                                   IsVisible="False"
                                   IsRunning="False"
                                   Color="#0F766E"
                                   WidthRequest="20"
                                   HeightRequest="20" />
                <Label x:Name="BusyLabel"
                       IsVisible="False"
                       Text="Working..."
                       FontFamily="OpenSansRegular"
                       TextColor="#334155" />
            </HorizontalStackLayout>
            <Border BackgroundColor="{StaticResource CardBackground}"
                    Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1"
                    Padding="12"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,180,180" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Entry Grid.Column="0"
                               x:Name="UrlEntry"
                               Placeholder="https://api.example.com/product/{id}"
                               Keyboard="Url"
                               ClearButtonVisibility="WhileEditing" />
                        <Picker Grid.Column="1"
                                x:Name="RunScopePicker">
                            <Picker.Items>
                                <x:String>Run Scope</x:String>
                                <x:String>Single Target Only</x:String>
                                <x:String>Spider Routes (All Discovered)</x:String>
                                <x:String>OpenAPI Routes (From Spec)</x:String>
                            </Picker.Items>
                        </Picker>
                        <Picker Grid.Row="0"
                                Grid.Column="2"
                                x:Name="TypeAwareModePicker">
                            <Picker.Items>
                                <x:String>Automatic (Type-Aware)</x:String>
                                <x:String>GET</x:String>
                                <x:String>POST</x:String>
                                <x:String>PUT</x:String>
                                <x:String>PATCH</x:String>
                                <x:String>DELETE</x:String>
                                <x:String>HEAD</x:String>
                                <x:String>OPTIONS</x:String>
                            </Picker.Items>
                        </Picker>
                        <Entry Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="1"
                               x:Name="OpenApiInputEntry"
                               Placeholder="Optional OpenAPI input (URL or path, e.g. /openapi.json or https://host/swagger/v1/swagger.json)" />
                        <Picker Grid.Row="1"
                                Grid.Column="1"
                                x:Name="PayloadLocationPicker">
                            <Picker.Items>
                                <x:String>Auto</x:String>
                                <x:String>Query</x:String>
                                <x:String>Path</x:String>
                                <x:String>Body</x:String>
                                <x:String>Header</x:String>
                                <x:String>Cookie</x:String>
                            </Picker.Items>
                        </Picker>
                        <Button Grid.Row="1"
                                Grid.Column="2"
                                Text="Load OpenAPI File"
                                HeightRequest="44"
                                CornerRadius="13"
                                Clicked="OnPickOpenApiFileClicked" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto" RowSpacing="8">
                        <Button Grid.Column="0"
                                Text="Spider Site + Coverage"
                                Clicked="OnSpiderSiteClicked"
                                BackgroundColor="#0F766E"
                                TextColor="White" />
                        <Button Grid.Column="1"
                                Text="Run Maximum Static + Dynamic Coverage"
                                Clicked="OnRunMaxCoverageClicked"
                                BackgroundColor="#0F766E"
                                TextColor="White" />
                    </Grid>
                    <Grid IsVisible="False"
                          HeightRequest="0"
                          Opacity="0">
                        <Entry x:Name="SingleTargetQueryEntry" />
                        <Editor x:Name="SingleTargetBodyEditor" />
                    </Grid>
                    <Border BackgroundColor="#F8FAFC"
                            Stroke="#D7E2E6"
                            StrokeThickness="1"
                            Padding="10"
                            StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Auth Profiles &amp; Baseline" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="Auto,20,*,110,Auto"
                                  ColumnSpacing="0"
                                  RowDefinitions="Auto">
                                <HorizontalStackLayout Grid.Column="0"
                                                       Spacing="8"
                                                       HorizontalOptions="Start"
                                                       VerticalOptions="Center">
                                    <Label Text="Role Matrix" VerticalOptions="Center"/>
                                    <Switch x:Name="RoleMatrixSwitch"
                                            IsToggled="False"
                                            HorizontalOptions="Start"
                                            VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Picker Grid.Column="2"
                                        x:Name="DefaultAuthProfilePicker"
                                        HorizontalOptions="Fill"
                                        Margin="0,0,0,0">
                                    <Picker.Items>
                                        <x:String>Run without credentials</x:String>
                                        <x:String>User credentials</x:String>
                                        <x:String>Admin credentials</x:String>
                                    </Picker.Items>
                                </Picker>

                                <HorizontalStackLayout Grid.Column="4"
                                                       Spacing="8"
                                                       HorizontalOptions="Start"
                                                       VerticalOptions="Center">
                                    <Label Text="Request Delay (ms)" VerticalOptions="Center" />
                                    <Entry x:Name="RequestDelayMsEntry"
                                           Text="0"
                                           Keyboard="Numeric"
                                           Placeholder="0"
                                           WidthRequest="140"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                                <Entry Grid.Row="0" Grid.Column="0" x:Name="UserBearerEntry" Placeholder="User bearer token" />
                                <Entry Grid.Row="0" Grid.Column="1" x:Name="AdminBearerEntry" Placeholder="Admin bearer token" />
                                <Entry Grid.Row="1" Grid.Column="0" x:Name="UserApiKeyEntry" Placeholder="User API key" />
                                <Entry Grid.Row="1" Grid.Column="1" x:Name="AdminApiKeyEntry" Placeholder="Admin API key" />
                                <Entry Grid.Row="2" Grid.Column="0" x:Name="UserCookieEntry" Placeholder="User cookie header" />
                                <Entry Grid.Row="2" Grid.Column="1" x:Name="AdminCookieEntry" Placeholder="Admin cookie header" />
                                <Entry Grid.Row="3" Grid.Column="0" x:Name="UserExtraHeadersEntry" Placeholder="User extra headers (X-Key:val; X-Env:prod)" />
                                <Entry Grid.Row="3" Grid.Column="1" x:Name="AdminExtraHeadersEntry" Placeholder="Admin extra headers (X-Key:val; X-Env:prod)" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" RowDefinitions="Auto">
                                <Picker Grid.Column="0" x:Name="BaselineRunPicker" />
                                <Button Grid.Column="1" Text="Refresh Baselines" Clicked="OnRefreshBaselinesClicked" BackgroundColor="#6B7280" TextColor="White" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto">
                                <Label Grid.Column="0" Text="Manual Payload Mode" VerticalOptions="Center" />
                                <Switch Grid.Column="1" x:Name="ManualPayloadModeSwitch" IsToggled="False" HorizontalOptions="Start" />
                            </Grid>
                            <Editor x:Name="ManualPayloadsEditor"
                                    AutoSize="TextChanges"
                                    HeightRequest="96"
                                    Placeholder="Manual payloads (one per line). Prefix with xss://, ssrf://, redirect://, sql://, nosql://, cmd://, path://, or generic://.&#10;Use override: https://host/path to run a direct request. Scheme variants follow the target/spec base: http stays http, https stays https." />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Label x:Name="IndividualTestsSectionAnchor" Text="Individual Security Tests" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8" RowDefinitions="Auto,Auto,Auto">
                <Button Grid.Row="0" Grid.Column="0" Text="Test SSRF" Clicked="OnTestSsrfClicked" />
                <Button Grid.Row="0" Grid.Column="1" Text="Test XSS" Clicked="OnTestXssClicked" />
                <Button Grid.Row="1" Grid.Column="0" Text="Test SQLi" Clicked="OnTestSqliClicked" />
                <Button Grid.Row="1" Grid.Column="1" Text="Test Headers" Clicked="OnTestHeadersClicked" />
                <Button Grid.Row="2" Grid.Column="0" Text="Test CORS" Clicked="OnTestCorsClicked" />
                <Button Grid.Row="2" Grid.Column="1" Text="Test Methods" Clicked="OnTestMethodsClicked" />
            </Grid>

            <Label x:Name="AppStandardsSectionAnchor" Text="Application &amp; API-Specific Standards" FontAttributes="Bold" HorizontalTextAlignment="Center" Margin="0,10,0,6" />
            <Label Text="OWASP API Security Top 10" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <Button Grid.Row="0" Grid.Column="0" Text="API1: BOLA" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API1" />
                <Button Grid.Row="0" Grid.Column="1" Text="API2: Broken Authentication" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API2" />
                <Button Grid.Row="1" Grid.Column="0" Text="API3: Broken Object Property Level Auth" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API3" />
                <Button Grid.Row="1" Grid.Column="1" Text="API4: Unrestricted Resource Consumption" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API4" />
                <Button Grid.Row="2" Grid.Column="0" Text="API5: Broken Function Level Authorization" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API5" />
                <Button Grid.Row="2" Grid.Column="1" Text="API6: Unrestricted Access to Sensitive Business Flows" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API6" />
                <Button Grid.Row="3" Grid.Column="0" Text="API7: SSRF" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API7" />
                <Button Grid.Row="3" Grid.Column="1" Text="API8: Security Misconfiguration" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API8" />
                <Button Grid.Row="4" Grid.Column="0" Text="API9: Improper Inventory Management" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API9" />
                <Button Grid.Row="4" Grid.Column="1" Text="API10: Unsafe Consumption of APIs" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP API Security Top 10|API10" />
            </Grid>
            <Label Text="OWASP ASVS" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <Button Grid.Row="0" Grid.Column="0" Text="V2 Authentication Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV2" />
                <Button Grid.Row="0" Grid.Column="1" Text="V3 Session Management Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV3" />
                <Button Grid.Row="1" Grid.Column="0" Text="V4 Access Control Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV4" />
                <Button Grid.Row="1" Grid.Column="1" Text="V5 Validation/Sanitization Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV5" />
                <Button Grid.Row="2" Grid.Column="0" Text="V6 Stored Cryptography Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV6" />
                <Button Grid.Row="2" Grid.Column="1" Text="V7 Error Handling &amp; Logging Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV7" />
                <Button Grid.Row="3" Grid.Column="0" Text="V8 Data Protection Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV8" />
                <Button Grid.Row="3" Grid.Column="1" Text="V9 Communications Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV9" />
                <Button Grid.Row="4" Grid.Column="0" Text="V13 API/Web Service Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV13" />
                <Button Grid.Row="4" Grid.Column="1" Text="V14 Config/HTTP Security Verification" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP ASVS|ASVSV14" />
            </Grid>
            <Label Text="OWASP MASVS" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto">
                <Button Grid.Row="0" Grid.Column="0" Text="MASVS-AUTH" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP MASVS|MASVSAUTH" />
                <Button Grid.Row="0" Grid.Column="1" Text="MASVS-NETWORK" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP MASVS|MASVSNETWORK" />
                <Button Grid.Row="1" Grid.Column="0" Text="MASVS-STORAGE/PRIVACY" Clicked="OnRunFrameworkTestClicked" CommandParameter="OWASP MASVS|MASVSSTORAGE" />
            </Grid>
            <Label Text="Cloud Security Alliance API Security guidance" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto">
                <Button Grid.Row="0" Grid.Column="0" Text="Identity &amp; Access Controls" Clicked="OnRunFrameworkTestClicked" CommandParameter="Cloud Security Alliance API Security guidance|CSAAPIIAM" />
                <Button Grid.Row="0" Grid.Column="1" Text="API Input/Injection Controls" Clicked="OnRunFrameworkTestClicked" CommandParameter="Cloud Security Alliance API Security guidance|CSAAPIINJ" />
                <Button Grid.Row="1" Grid.Column="0" Text="Transport/Configuration Controls" Clicked="OnRunFrameworkTestClicked" CommandParameter="Cloud Security Alliance API Security guidance|CSAAPITRANS" />
            </Grid>

            <Label x:Name="UsFederalSectionAnchor" Text="U.S. Federal / Government Standards" FontAttributes="Bold" HorizontalTextAlignment="Center" Margin="0,10,0,6" />
            <Label Text="NIST SP 800-53" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <Button Text="AC-2 Account Management" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53AC2" />
                <Button Grid.Column="1" Text="AC-3 Access Enforcement" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53AC3" />
                <Button Grid.Row="1" Text="AC-6 Least Privilege" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53AC6" />
                <Button Grid.Row="1" Grid.Column="1" Text="IA-2 Identification &amp; Authentication" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53IA2" />
                <Button Grid.Row="2" Text="IA-5 Authenticator Management" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53IA5" />
                <Button Grid.Row="2" Grid.Column="1" Text="SC-5 Denial of Service Protection" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53SC5" />
                <Button Grid.Row="3" Text="SC-7 Boundary Protection" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53SC7" />
                <Button Grid.Row="3" Grid.Column="1" Text="SC-8 Transmission Confidentiality/Integrity" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53SC8" />
                <Button Grid.Row="4" Text="SC-23 Session Authenticity" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53SC23" />
                <Button Grid.Row="4" Grid.Column="1" Text="SI-10 Information Input Validation" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53SI10" />
                <Button Grid.Row="5" Text="AU-2 Event Logging" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53AU2" />
                <Button Grid.Row="5" Grid.Column="1" Text="AU-9 Audit Protection" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53AU9" />
                <Button Grid.Row="6" Text="AU-12 Audit Generation" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53AU12" />
                <Button Grid.Row="6" Grid.Column="1" Text="CM-6 Configuration Settings" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53CM6" />
                <Button Grid.Row="7" Text="CM-7 Least Functionality" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53CM7" />
                <Button Grid.Row="7" Grid.Column="1" Text="SA-11 Developer Security Testing" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53SA11" />
                <Button Grid.Row="8" Text="IR-6 Incident Reporting" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53IR6" />
                <Button Grid.Row="8" Grid.Column="1" Text="RA-5 Vulnerability Monitoring/Scanning" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-53|N53RA5" />
            </Grid>
            <Label Text="NIST SP 800-61" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto">
                <Button Text="Detection and Analysis" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-61|N61DETECT" />
                <Button Grid.Column="1" Text="Containment Strategy Check" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-61|N61CONTAIN" />
                <Button Grid.Row="1" Text="Eradication Indicators" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-61|N61ERADICATE" />
                <Button Grid.Row="1" Grid.Column="1" Text="Recovery/Reoccurrence Check" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-61|N61RECOVER" />
            </Grid>
            <Label Text="NIST SP 800-63" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto">
                <Button Text="AAL Session/Auth Strength Check" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-63|N63AAL" />
                <Button Grid.Column="1" Text="Replay Resistance Check" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-63|N63REPLAY" />
                <Button Grid.Row="1" Text="Token/Session Binding Check" Clicked="OnRunFrameworkTestClicked" CommandParameter="NIST SP 800-63|N63SESSION" />
            </Grid>
            <Label Text="NIST SP 800-207" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto">
