            <Label x:Name="CveSectionAnchor" Text="CVE &amp; Test Reference" FontAttributes="Bold" />
            <VerticalStackLayout Spacing="6">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="6" RowDefinitions="Auto,Auto">
                <Button Text="Sync Complete CVE Corpus (NVD)"
                        Clicked="OnSyncCveCorpusClicked" />
                <Button Grid.Column="1"
                        Text="Build CVE Function Map"
                        Clicked="OnBuildFunctionMapClicked" />
                <Button Grid.Row="1"
                        Text="Load Local CVE Corpus Summary"
                        Clicked="OnLoadCveCorpusClicked" />
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Text="Load Function Map Paged View"
                        Clicked="OnLoadFunctionMapPagedClicked" />
            </Grid>
            </VerticalStackLayout>
            <Label x:Name="ResultsSectionAnchor"
                   Text="Results"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level2" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto" RowSpacing="6">
                <Button Text="Load Log"
                        Clicked="OnLoadLogClicked" />
                <Button Grid.Column="1"
                        Text="Save Log"
                        Clicked="OnSaveLogClicked" />
            </Grid>
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="6">
                <Button x:Name="PrevPageButton"
                        Text="Prev Page"
                        Clicked="OnPrevCvePageClicked"
                        BackgroundColor="#6B7280"
                        TextColor="White"
                        HorizontalOptions="Fill"
                        IsEnabled="False" />
                <Button Grid.Column="1"
                        x:Name="NextPageButton"
                        Text="Next Page"
                        Clicked="OnNextCvePageClicked"
                        BackgroundColor="#6B7280"
                        TextColor="White"
                        HorizontalOptions="Fill"
                        IsEnabled="False" />
                <Label Grid.Row="1"
                       Grid.ColumnSpan="2"
                       x:Name="ResultsPageLabel"
                       Margin="0,6,0,0"
                       HorizontalTextAlignment="Center"
                       TextColor="#475569"
                       Text="" />
            </Grid>
            <Editor x:Name="ResultsEditor"
                    AutoSize="TextChanges"
                    MinimumHeightRequest="420"
                    IsReadOnly="True"
                    BackgroundColor="White"
                    Placeholder="Test results will appear here." />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="3" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,0">
                <Entry Grid.Row="0"
                       Placeholder="Search specific CVE (e.g., CVE-2024-12345)"
                       x:Name="CveSearchEntry" />
                <Button Grid.Row="0"
                        Grid.Column="1"
                        Text="Find CVE"
                        HeightRequest="44"
                        Clicked="OnFindCveClicked" />
                <Entry Grid.Row="1"
                       x:Name="CvePageEntry"
                       Placeholder="Page #"
                       Keyboard="Numeric" />
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Text="Go To Page"
                        HeightRequest="44"
                        Clicked="OnGoToCvePageClicked" />
                <Picker Grid.Row="2"
                        x:Name="PriorityFilterPicker"
                        SelectedIndexChanged="OnPriorityFilterChanged">
                    <Picker.Items>
                        <x:String>Off</x:String>
                        <x:String>High</x:String>
                        <x:String>Medium</x:String>
                        <x:String>Low</x:String>
                    </Picker.Items>
                </Picker>
                <Button Grid.Row="2"
                        Grid.Column="1"
                        Text="Apply Priority Filter"
                        HeightRequest="44"
                        Clicked="OnApplyPriorityFilterClicked" />
            </Grid>
            <BoxView x:Name="BottomSectionAnchor"
                     Margin="0,-12,0,0"
                     HeightRequest="1"
                     Opacity="0" />
        </VerticalStackLayout>
    </ScrollView>

